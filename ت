<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>نظام إدارة طوارئ الإخلاء</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
:root{
  --bg:#0f1720; --panel:#17212c; --panel2:#1e2a37; --border:#2a3846;
  --text:#e8edf2; --muted:#8ea1b3;
  --safe:#1f9d55; --safe-bg:#123322;
  --missing:#c23434; --missing-bg:#3a1414;
  --accent:#f0a500; --accent-dark:#c98600;
  --focus:#4fb3ff;
}
*{box-sizing:border-box;}
body{margin:0;font-family:'Tahoma','Segoe UI',sans-serif;background:var(--bg);color:var(--text);font-size:16px;}
header{
  background:linear-gradient(180deg,#1a2530,#0f1720);
  border-bottom:3px solid var(--accent);
  padding:10px 14px;position:sticky;top:0;z-index:20;
}
header h1{margin:0 0 8px;font-size:19px;letter-spacing:.3px;display:flex;align-items:center;gap:8px;}
header h1 .dot{width:10px;height:10px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px var(--accent);}
.stats{display:flex;gap:8px;flex-wrap:wrap;}
.stat{flex:1;min-width:90px;background:var(--panel2);border:1px solid var(--border);border-radius:10px;padding:8px 10px;text-align:center;}
.stat b{display:block;font-size:22px;line-height:1.2;}
.stat span{font-size:11px;color:var(--muted);}
.stat.total b{color:var(--focus);}
.stat.safe b{color:var(--safe);}
.stat.missing b{color:var(--missing);}

main{padding:12px;max-width:900px;margin:0 auto;}
.card{background:var(--panel);border:1px solid var(--border);border-radius:12px;padding:12px;margin-bottom:12px;}
.card h2{margin:0 0 10px;font-size:15px;color:var(--accent);}

.tabs{display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap;}
.tab-btn{
  flex:1;min-width:100px;padding:9px 6px;background:var(--panel2);border:1px solid var(--border);
  color:var(--muted);border-radius:8px;font-size:13px;cursor:pointer;
}
.tab-btn.active{background:var(--accent);color:#1a1200;border-color:var(--accent);font-weight:bold;}
.tab-content{display:none;}
.tab-content.active{display:block;}

label{display:block;font-size:12px;color:var(--muted);margin-bottom:4px;}
input[type=text], input[type=file], input[type=url], textarea, select{
  width:100%;background:var(--panel2);border:1px solid var(--border);color:var(--text);
  padding:9px;border-radius:8px;font-size:14px;margin-bottom:8px;font-family:inherit;
}
textarea{min-height:100px;resize:vertical;}
input:focus, textarea:focus, select:focus, button:focus{outline:2px solid var(--focus);outline-offset:1px;}

button{
  cursor:pointer;border:none;border-radius:8px;padding:9px 14px;font-size:14px;font-weight:bold;
  background:var(--accent);color:#1a1200;
}
button:active{transform:scale(.97);}
button.secondary{background:var(--panel2);color:var(--text);border:1px solid var(--border);}
.row{display:flex;gap:8px;flex-wrap:wrap;}
.row > *{flex:1;min-width:120px;}

.status-msg{font-size:12px;padding:8px;border-radius:8px;margin-top:6px;display:none;}
.status-msg.ok{display:block;background:var(--safe-bg);color:#8fe0ac;border:1px solid var(--safe);}
.status-msg.err{display:block;background:var(--missing-bg);color:#f0a0a0;border:1px solid var(--missing);}

.controls{display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap;}
.controls input, .controls select{margin-bottom:0;}
.controls .search{flex:2;min-width:160px;}
.controls .filter{flex:1;min-width:140px;}

.list-info{font-size:12px;color:var(--muted);margin-bottom:6px;}

table{width:100%;border-collapse:collapse;font-size:13px;}
thead th{
  position:sticky;top:0;background:var(--panel2);color:var(--muted);font-size:11px;
  padding:6px 4px;text-align:right;border-bottom:1px solid var(--border);
}
tbody td{padding:7px 4px;border-bottom:1px solid var(--border);vertical-align:middle;}
tbody tr.safe-row{background:var(--safe-bg);}
tbody tr.missing-row td:first-child{border-right:3px solid var(--missing);}
.name-cell{font-weight:bold;}
.sub-cell{font-size:11px;color:var(--muted);}

.badge{display:inline-block;padding:3px 8px;border-radius:20px;font-size:11px;font-weight:bold;}
.badge.safe{background:var(--safe);color:#fff;}
.badge.pending{background:#40505f;color:#cdd8e0;}

.att-btn{padding:6px 10px;font-size:12px;background:var(--safe);color:#fff;border-radius:6px;}
.att-btn.undo{background:var(--panel2);color:var(--text);border:1px solid var(--border);}

.table-wrap{max-height:55vh;overflow:auto;border:1px solid var(--border);border-radius:8px;}

footer{padding:20px 12px 40px;text-align:center;color:var(--muted);font-size:11px;}
.hint{font-size:11px;color:var(--muted);margin-top:2px;}
</style>
</head>
<body>

<header>
  <h1><span class="dot"></span> نظام إدارة طوارئ الإخلاء</h1>
  <div class="stats">
    <div class="stat total"><b id="statTotal">0</b><span>إجمالي القوى</span></div>
    <div class="stat safe"><b id="statSafe">0</b><span>آمنون</span></div>
    <div class="stat missing"><b id="statMissing">0</b><span>مفقودون</span></div>
  </div>
</header>

<main>

  <div class="card">
    <h2>1) استيراد بيانات الموظفين</h2>
    <div class="tabs">
      <button class="tab-btn active" data-tab="paste">لصق مباشر</button>
      <button class="tab-btn" data-tab="excel">ملف إكسل</button>
      <button class="tab-btn" data-tab="gsheet">قوقل شيت</button>
    </div>

    <div class="tab-content active" id="tab-paste">
      <label>الصق بيانات الموظفين (RFID, ID, الاسم, القسم, الموقع) — يدعم أسماء تحتوي فواصل بين علامتي تنصيص</label>
      <textarea id="pasteArea" placeholder='مثال:
RFID,ID,الاسم,القسم,الموقع
1234567,90011,"السويلم, أمل",أمن صناعي,برج A
2233445,90012,محمد العتيبي,عمليات,برج B'></textarea>
      <button id="btnParsePaste">استيراد من النص الملصق</button>
    </div>

    <div class="tab-content" id="tab-excel">
      <label>اختر ملف Excel (.xlsx / .xls)</label>
      <input type="file" id="excelFile" accept=".xlsx,.xls">
      <div class="hint">يتطلب اتصال إنترنت عند أول تحميل للصفحة لتفعيل مكتبة قراءة الإكسل، ثم يعمل التحليل محلياً.</div>
    </div>

    <div class="tab-content" id="tab-gsheet">
      <label>رابط النشر على الويب (CSV) من قوقل شيت</label>
      <input type="url" id="gsheetUrl" placeholder="https://docs.google.com/spreadsheets/d/e/.../pub?output=csv">
      <button id="btnLoadGsheet">سحب البيانات الآن</button>
      <div class="hint">ملف &gt; مشاركة &gt; نشر على الويب &gt; اختر CSV. يتطلب اتصال إنترنت وقت السحب.</div>
    </div>

    <div id="importStatus" class="status-msg"></div>
  </div>

  <div class="card">
    <h2>2) قائمة الموظفين</h2>
    <div class="controls">
      <input type="text" id="searchBox" class="search" placeholder="بحث بالاسم / الرقم / RFID...">
      <select id="locationFilter" class="filter">
        <option value="">كل المواقع</option>
      </select>
      <select id="statusFilter" class="filter">
        <option value="">كل الحالات</option>
        <option value="safe">آمن فقط</option>
        <option value="pending">مفقود / لم يُؤكد</option>
      </select>
    </div>
    <div class="list-info" id="listInfo">لا توجد بيانات مستوردة بعد.</div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>الحالة</th>
            <th>الاسم</th>
            <th>الرقم / RFID</th>
            <th>القسم</th>
            <th>الموقع</th>
            <th>إجراء</th>
          </tr>
        </thead>
        <tbody id="tableBody"></tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <h2>3) التصدير</h2>
    <div class="row">
      <button id="btnExportSafe">تصدير كشف الآمنين (CSV)</button>
      <button class="secondary" id="btnResetAll">تصفير حالة الحضور للجميع</button>
    </div>
  </div>

</main>

<footer>نظام مستقل يعمل بدون إنترنت (باستثناء تحميل ملفات Excel أو سحب قوقل شيت) — إعداد داخلي</footer>

<script>
'use strict';

// ---------- STATE ----------
let records = [];        // { rfid, id, name, dept, location, safe:bool }
let renderLimit = 100;
let searchTerm = '';
let locFilter = '';
let statusFilterVal = '';

// ---------- TAB SWITCHING ----------
document.querySelectorAll('.tab-btn').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(c=>c.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-'+btn.dataset.tab).classList.add('active');
  });
});

function showStatus(msg, ok){
  const el = document.getElementById('importStatus');
  el.textContent = msg;
  el.className = 'status-msg ' + (ok ? 'ok' : 'err');
}

// ---------- SMART CSV PARSER (handles quoted commas) ----------
function parseDelimitedText(text){
  const rows = [];
  let row = [], field = '', inQuotes = false;
  for(let i=0;i<text.length;i++){
    const c = text[i];
    if(inQuotes){
      if(c === '"'){
        if(text[i+1] === '"'){ field += '"'; i++; }
        else inQuotes = false;
      } else field += c;
    } else {
      if(c === '"') inQuotes = true;
      else if(c === ',' || c === '\t'){ row.push(field); field=''; }
      else if(c === '\n'){ row.push(field); rows.push(row); row=[]; field=''; }
      else if(c === '\r'){ /* skip */ }
      else field += c;
    }
  }
  if(field.length || row.length){ row.push(field); rows.push(row); }
  return rows.filter(r => r.some(f => f.trim() !== ''));
}

// ---------- COLUMN MAPPING ----------
function mapColumns(rows){
  if(!rows.length) return [];
  const headerRow = rows[0].map(h => (h||'').toString().trim().toLowerCase());
  const isHeader = headerRow.some(h =>
    /rfid|شريحة|بطاقة|id|هوية|رقم|اسم|name|قسم|dept|موقع|location|برج/.test(h)
  );

  const find = (patterns) => headerRow.findIndex(h => patterns.some(p => h.includes(p)));

  let idxRfid, idxId, idxName, idxDept, idxLoc;
  let dataRows;

  if(isHeader){
    idxRfid = find(['rfid','شريحة']);
    idxId   = find(['id','هوية','رقم الموظف','الرقم الوظيفي']);
    idxName = find(['اسم','name']);
    idxDept = find(['قسم','dept','إدارة']);
    idxLoc  = find(['موقع','location','برج','مبنى']);
    dataRows = rows.slice(1);
  } else {
    dataRows = rows;
  }

  // Fallback to fixed positional order: RFID(0), ID(1), Name(2), Dept(3), Location(4)
  if(idxRfid === undefined || idxRfid < 0) idxRfid = 0;
  if(idxId === undefined || idxId < 0) idxId = 1;
  if(idxName === undefined || idxName < 0) idxName = 2;
  if(idxDept === undefined || idxDept < 0) idxDept = 3;
  if(idxLoc === undefined || idxLoc < 0) idxLoc = 4;

  return dataRows.map(r => ({
    rfid: (r[idxRfid]||'').toString().trim(),
    id: (r[idxId]||'').toString().trim(),
    name: (r[idxName]||'').toString().trim(),
    dept: (r[idxDept]||'').toString().trim(),
    location: (r[idxLoc]||'').toString().trim(),
    safe: false
  })).filter(rec => rec.name || rec.id || rec.rfid);
}

function ingest(rows, sourceLabel){
  const parsed = mapColumns(rows);
  if(!parsed.length){
    showStatus('لم يتم العثور على سجلات صالحة في ' + sourceLabel, false);
    return;
  }
  records = parsed;
  showStatus('تم استيراد ' + records.length + ' سجل بنجاح من ' + sourceLabel, true);
  buildLocationFilter();
  renderTable();
  updateStats();
}

// ---------- PASTE ----------
document.getElementById('btnParsePaste').addEventListener('click', ()=>{
  const text = document.getElementById('pasteArea').value.trim();
  if(!text){ showStatus('الرجاء لصق البيانات أولاً.', false); return; }
  const rows = parseDelimitedText(text);
  ingest(rows, 'النص الملصق');
});

// ---------- EXCEL ----------
document.getElementById('excelFile').addEventListener('change', (e)=>{
  const file = e.target.files[0];
  if(!file) return;
  if(typeof XLSX === 'undefined'){
    showStatus('تعذر تحميل مكتبة قراءة الإكسل (يلزم اتصال إنترنت مرة واحدة).', false);
    return;
  }
  const reader = new FileReader();
  reader.onload = (evt)=>{
    try{
      const wb = XLSX.read(evt.target.result, {type:'array'});
      const ws = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSX.utils.sheet_to_json(ws, {header:1, defval:''});
      ingest(rows, 'ملف ' + file.name);
    }catch(err){
      showStatus('خطأ في قراءة ملف الإكسل: ' + err.message, false);
    }
  };
  reader.readAsArrayBuffer(file);
});

// ---------- GOOGLE SHEET ----------
document.getElementById('btnLoadGsheet').addEventListener('click', async ()=>{
  const url = document.getElementById('gsheetUrl').value.trim();
  if(!url){ showStatus('الرجاء إدخال رابط CSV من قوقل شيت.', false); return; }
  showStatus('جارِ سحب البيانات...', true);
  try{
    const res = await fetch(url);
    if(!res.ok) throw new Error('HTTP ' + res.status);
    const text = await res.text();
    const rows = parseDelimitedText(text);
    ingest(rows, 'قوقل شيت');
  }catch(err){
    showStatus('تعذر سحب البيانات (تحقق من الرابط والاتصال بالإنترنت): ' + err.message, false);
  }
});

// ---------- FILTERS ----------
function buildLocationFilter(){
  const sel = document.getElementById('locationFilter');
  const current = sel.value;
  const locs = [...new Set(records.map(r=>r.location).filter(Boolean))].sort();
  sel.innerHTML = '<option value="">كل المواقع</option>' +
    locs.map(l=>`<option value="${escapeHtml(l)}">${escapeHtml(l)}</option>`).join('');
  sel.value = locs.includes(current) ? current : '';
}

document.getElementById('searchBox').addEventListener('input', (e)=>{
  searchTerm = e.target.value.trim().toLowerCase();
  renderTable();
});
document.getElementById('locationFilter').addEventListener('change', (e)=>{
  locFilter = e.target.value;
  renderTable();
});
document.getElementById('statusFilter').addEventListener('change', (e)=>{
  statusFilterVal = e.target.value;
  renderTable();
});

function escapeHtml(s){
  return (s||'').toString()
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ---------- RENDER (DocumentFragment + virtual limit) ----------
function getFiltered(){
  return records.filter(r=>{
    if(locFilter && r.location !== locFilter) return false;
    if(statusFilterVal === 'safe' && !r.safe) return false;
    if(statusFilterVal === 'pending' && r.safe) return false;
    if(searchTerm){
      const hay = (r.name+' '+r.id+' '+r.rfid+' '+r.dept).toLowerCase();
      if(!hay.includes(searchTerm)) return false;
    }
    return true;
  });
}

function renderTable(){
  const tbody = document.getElementById('tableBody');
  const filtered = getFiltered();
  const shown = filtered.slice(0, renderLimit);

  const frag = document.createDocumentFragment();
  shown.forEach(rec=>{
    const tr = document.createElement('tr');
    tr.className = rec.safe ? 'safe-row' : 'missing-row';

    const tdStatus = document.createElement('td');
    const badge = document.createElement('span');
    badge.className = 'badge ' + (rec.safe ? 'safe' : 'pending');
    badge.textContent = rec.safe ? 'آمن' : 'غير مؤكد';
    tdStatus.appendChild(badge);

    const tdName = document.createElement('td');
    tdName.innerHTML = `<div class="name-cell">${escapeHtml(rec.name)}</div><div class="sub-cell">${escapeHtml(rec.rfid)}</div>`;

    const tdId = document.createElement('td');
    tdId.textContent = rec.id;

    const tdDept = document.createElement('td');
    tdDept.textContent = rec.dept;

    const tdLoc = document.createElement('td');
    tdLoc.textContent = rec.location;

    const tdAction = document.createElement('td');
    const btn = document.createElement('button');
    btn.className = 'att-btn' + (rec.safe ? ' undo' : '');
    btn.textContent = rec.safe ? 'تراجع' : 'حضور';
    btn.addEventListener('click', ()=>{
      rec.safe = !rec.safe;
      renderTable();
      updateStats();
    });
    tdAction.appendChild(btn);

    tr.append(tdStatus, tdName, tdId, tdDept, tdLoc, tdAction);
    frag.appendChild(tr);
  });

  tbody.innerHTML = '';
  tbody.appendChild(frag);

  const info = document.getElementById('listInfo');
  if(!records.length){
    info.textContent = 'لا توجد بيانات مستوردة بعد.';
  } else if(filtered.length > renderLimit){
    info.textContent = `عرض ${renderLimit} من أصل ${filtered.length} نتيجة مطابقة (استخدم البحث للوصول لسجل محدد) — الإجمالي الكلي: ${records.length}`;
  } else {
    info.textContent = `عرض ${filtered.length} من أصل ${records.length} سجل`;
  }
}

function updateStats(){
  document.getElementById('statTotal').textContent = records.length;
  const safeCount = records.filter(r=>r.safe).length;
  document.getElementById('statSafe').textContent = safeCount;
  document.getElementById('statMissing').textContent = records.length - safeCount;
}

// ---------- EXPORT ----------
document.getElementById('btnExportSafe').addEventListener('click', ()=>{
  const safeList = records.filter(r=>r.safe);
  if(!safeList.length){ alert('لا يوجد موظفون مسجلون كآمنين بعد.'); return; }
  const header = 'RFID,ID,الاسم,القسم,الموقع\n';
  const rows = safeList.map(r =>
    [r.rfid, r.id, `"${(r.name||'').replace(/"/g,'""')}"`, r.dept, r.location].join(',')
  ).join('\n');
  const csv = '\uFEFF' + header + rows;
  const blob = new Blob([csv], {type:'text/csv;charset=utf-8;'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  const ts = new Date().toISOString().slice(0,19).replace(/[:T]/g,'-');
  a.download = 'كشف_الآمنين_' + ts + '.csv';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
});

document.getElementById('btnResetAll').addEventListener('click', ()=>{
  if(!records.length) return;
  if(!confirm('هل تريد تصفير حالة الحضور لجميع الموظفين؟')) return;
  records.forEach(r=> r.safe = false);
  renderTable();
  updateStats();
});

// ---------- INIT ----------
updateStats();
renderTable();
</script>
</body>
</html>
