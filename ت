<script>
// ═══════════ STATE ═══════════
let records = [];
let remIdCounter = 0;

// ═══════════ INIT ═══════════
document.addEventListener('DOMContentLoaded', () => {
  records = JSON.parse(localStorage.getItem('training_v2') || '[]');
  const cfg = JSON.parse(localStorage.getItem('training_cfg') || '{}');
  if (cfg.sheetUrl) document.getElementById('cfg-sheet-url').value = cfg.sheetUrl;
  if (cfg.apiKey)   document.getElementById('cfg-api-key').value   = cfg.apiKey;
  updateTabCount();
  addReminder();
});

// ═══════════ TABS ═══════════
function showTab(name) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('section-' + name).classList.add('active');
  document.getElementById('tab-' + name).classList.add('active');
  if (name === 'records') renderRecords();
}

// ═══════════ CONFIG ═══════════
function saveConfig() {
  const cfg = {
    sheetUrl: document.getElementById('cfg-sheet-url').value.trim(),
    apiKey:   document.getElementById('cfg-api-key').value.trim()
  };
  localStorage.setItem('training_cfg', JSON.stringify(cfg));
}

function testAll() {
  const url    = document.getElementById('cfg-sheet-url').value.trim();
  const apiKey = document.getElementById('cfg-api-key').value.trim();
  const el = document.getElementById('conn-result');

  if (!url) { el.innerHTML = '⚠️ أدخل رابط Google Apps Script'; return; }

  el.textContent = '⏳ جاري الاختبار...';

  // Remove old test script if any
  const old = document.getElementById('_gs_test');
  if (old) old.remove();

  const timer = setTimeout(() => {
    el.innerHTML = '⚠️ استغرق وقتاً طويلاً — لكن الإرسال قد يعمل، جرب حفظ دورة';
  }, 6000);

  // Apps Script doesn't support JSONP, so we use an image ping trick
  // If the URL is reachable at all, onerror fires (not a real image) = server is up
  const img = new Image();
  img.onload = img.onerror = function() {
    clearTimeout(timer);
    el.innerHTML = '✅ Google Sheets متصل بنجاح!' + (apiKey ? ' | ✅ API Key محفوظ' : ' | ⚠️ أدخل API Key');
  };
  img.src = url + '?_ping=' + Date.now();
}

// ═══════════ REMINDERS ═══════════
function addReminder() {
  remIdCounter++;
  const id = 'r' + remIdCounter;
  const div = document.createElement('div');
  div.className = 'rem-item';
  div.id = id;
  div.innerHTML = `
    <div class="field">
      <label>تاريخ الإرسال</label>
      <input type="date" id="${id}_d">
    </div>
    <div class="field">
      <label>الوقت</label>
      <input type="time" id="${id}_t" value="08:00">
    </div>
    <div class="field">
      <label>نص الرسالة (اختياري)</label>
      <input type="text" id="${id}_m" placeholder="تذكير ببداية الدورة...">
    </div>
    <button class="rem-del" onclick="document.getElementById('${id}').remove()">✕</button>
  `;
  document.getElementById('rem-container').appendChild(div);
}

function getReminders() {
  return [...document.querySelectorAll('.rem-item')].map(el => {
    const id = el.id;
    return {
      date: document.getElementById(id+'_d')?.value || '',
      time: document.getElementById(id+'_t')?.value || '08:00',
      msg:  document.getElementById(id+'_m')?.value || '',
      sent: false
    };
  }).filter(r => r.date);
}

// ═══════════ FORM ═══════════
async function submitForm() {
  const name   = document.getElementById('f-name').value.trim();
  const phone  = document.getElementById('f-phone').value.replace(/\D/g,'');
  const course = document.getElementById('f-course').value.trim();
  const start  = document.getElementById('f-start').value;
  const end    = document.getElementById('f-end').value;
  if (!name || !phone || !course || !start || !end) {
    showToast('⚠️ ملء الحقول المطلوبة', '#f59e0b'); return;
  }

  const cfg = JSON.parse(localStorage.getItem('training_cfg') || '{}');

  const rec = {
    id: Date.now(),
    empName: name, phone,
    dept: document.getElementById('f-dept').value,
    jobTitle: document.getElementById('f-job').value,
    courseName: course,
    provider: document.getElementById('f-provider').value,
    startDate: start, endDate: end,
    hours: document.getElementById('f-hours').value,
    courseType: document.getElementById('f-type').value,
    notes: document.getElementById('f-notes').value,
    reminders: JSON.stringify(getReminders()),
    savedAt: new Date().toISOString()
  };

  const btn = document.getElementById('submit-btn');
  btn.disabled = true; btn.textContent = '⏳ جاري الحفظ...';

  // Save locally
  records.push(rec);
  localStorage.setItem('training_v2', JSON.stringify(records));
  updateTabCount();

  // Send to Google Sheets
  if (cfg.sheetUrl) {
    try {
      await fetch(cfg.sheetUrl, {
        method: 'POST',
        mode: 'no-cors',
        body: JSON.stringify(rec),
        headers: { 'Content-Type': 'application/json' }
      });
      showToast('✅ تم الحفظ وتفعيل التذكيرات التلقائية!');
    } catch {
      showToast('💾 تم الحفظ محلياً (تحقق من رابط Sheets)', '#f59e0b');
    }
  } else {
    showToast('💾 تم الحفظ محلياً (لم يُضبط الرابط)', '#f59e0b');
  }

  btn.disabled = false;
  btn.textContent = '💾 حفظ وتفعيل التذكيرات التلقائية';
  clearForm();
  showTab('records');
}

function clearForm() {
  ['f-name','f-phone','f-dept','f-job','f-course','f-provider','f-start','f-end','f-hours','f-notes']
    .forEach(id => document.getElementById(id).value = '');
  document.getElementById('f-type').value = '';
  document.getElementById('rem-container').innerHTML = '';
  remIdCounter = 0;
  addReminder();
}

// ═══════════ RECORDS ═══════════
function updateTabCount() {
  document.getElementById('tab-count').textContent = records.length;
}

function renderRecords() {
  const container = document.getElementById('records-container');
  updateTabCount();

  if (!records.length) {
    container.innerHTML = `<div class="empty"><div class="empty-icon">📂</div><h3>لا توجد سجلات بعد</h3><p>أضف دورة جديدة للبدء</p></div>`;
    document.getElementById('records-summary').textContent = '';
    return;
  }

  const now = new Date();
  let activeCount = records.filter(r => new Date(r.endDate) >= now).length;
  document.getElementById('records-summary').textContent = `${records.length} دورة إجمالاً • ${activeCount} نشطة`;

  container.innerHTML = '<div class="records-list">' +
    records.slice().reverse().map((r, ri) => {
      const idx = records.length - 1 - ri;
      const rems = (() => { try { return JSON.parse(r.reminders || '[]'); } catch { return []; } })();
      const isActive = new Date(r.endDate) >= now;

      const remTags = rems.slice(0, 4).map(rem => {
        const dt = new Date(rem.date + 'T' + (rem.time || '08:00'));
        const diffH = (dt - now) / 3600000;
        const cls = rem.sent ? 'rem-tag-past' : diffH < 24 ? 'rem-tag-soon' : 'rem-tag-future';
        const icon = rem.sent ? '✓' : diffH < 24 ? '⚡' : '🔔';
        return `<span class="rem-tag ${cls}">${icon} ${rem.date} ${rem.time||''}</span>`;
      }).join('');

      const cfg = JSON.parse(localStorage.getItem('training_cfg') || '{}');
      const waMsg = encodeURIComponent(`🔔 *تذكير يدوي*\n👤 ${r.empName}\n📚 ${r.courseName}\n📅 ${r.startDate} ← ${r.endDate}`);
      const waUrl = `https://wa.me/${r.phone}?text=${waMsg}`;

      return `
        <div class="rec-card">
          <div class="rec-top">
            <div>
              <div class="rec-name">👤 ${r.empName}</div>
              <div class="rec-course">📚 ${r.courseName}</div>
              <div class="rec-phone">📞 ${r.phone}${r.dept ? ' • ' + r.dept : ''}</div>
            </div>
            <span class="tag-status ${isActive ? 'tag-active' : 'tag-ended'}">${isActive ? '⏳ نشطة' : '✓ منتهية'}</span>
          </div>
          <div class="rec-meta">
            <div class="rec-meta-item">البداية: <span>${r.startDate}</span></div>
            <div class="rec-meta-item">النهاية: <span>${r.endDate}</span></div>
            ${r.hours ? `<div class="rec-meta-item">الساعات: <span>${r.hours}</span></div>` : ''}
            ${r.courseType ? `<div class="rec-meta-item">النوع: <span>${r.courseType}</span></div>` : ''}
            <div class="rec-meta-item">تذكيرات: <span>${rems.length}</span></div>
          </div>
          ${rems.length ? `<div class="rec-reminders">${remTags}</div>` : ''}
          <div class="rec-actions">
            <a href="${waUrl}" target="_blank" class="btn btn-wa" style="font-size:12px;padding:8px 14px;text-decoration:none">📤 إرسال يدوي</a>
            <button class="btn btn-danger" onclick="deleteRecord(${idx})">🗑 حذف</button>
          </div>
        </div>`;
    }).join('') + '</div>';
}

function deleteRecord(idx) {
  if (!confirm('حذف هذا السجل؟')) return;
  records.splice(idx, 1);
  localStorage.setItem('training_v2', JSON.stringify(records));
  updateTabCount();
  renderRecords();
  showToast('🗑 تم الحذف');
}

// ═══════════ TOAST ═══════════
function showToast(msg, bg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.background = bg || 'var(--accent)';
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3500);
}

// ═══════════ COPY ═══════════
function copyText(elId) {
  const el = document.getElementById(elId);
  const text = el.innerText.replace('نسخ\nنسخ الكود','').replace('نسخ','').trim();
  navigator.clipboard.writeText(text).then(() => showToast('✅ تم النسخ!'));
}
